---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import AboutIDE from '../components/AboutIDE.astro';
import SkillsGrid from '../components/SkillsGrid.astro';
import Certifications from '../components/Certifications.astro';
import Footer from '../components/Footer.astro';

import { parseCV } from '../utils/cvParser';

const cvData = parseCV('en');
const title = `${cvData.name} | ${cvData.title}`;
const description = `Portfolio of ${cvData.name}, a Full Stack Engineer specialized in clean code, BDD/TDD, and robust developer systems.`;
const keywords = `Kevin Hierro, Full Stack Engineer, Software Engineer, Portfolio, Clean Code, TDD, BDD, TypeScript, Kotlin, Python, React, Spring Boot`;
---

<Layout title={title} description={description} lang="en" keywords={keywords}>
  <Navigation lang="en" />
  
  <main>
    <Hero 
      lang="en"
      name={cvData.name}
      title={cvData.title}
      github={cvData.github}
      linkedin={cvData.linkedin}
      email={cvData.email}
    />
    
    <AboutIDE 
      lang="en"
      profileText={cvData.profile}
      education={cvData.education}
      experience={cvData.experience}
    />
    
    <SkillsGrid 
      lang="en"
      skillsList={cvData.skills}
    />
    
    <Certifications 
      lang="en"
      certificationsList={cvData.certifications}
    />
  </main>
  
  <Footer 
    lang="en"
    email={cvData.email}
    linkedin={cvData.linkedin}
    github={cvData.github}
  />
</Layout>
