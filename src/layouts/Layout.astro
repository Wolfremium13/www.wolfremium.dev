---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'es';
  keywords?: string;
  canonicalUrl?: string;
}

const { title, description, lang, keywords, canonicalUrl } = Astro.props;

const siteUrl = 'https://www.wolfremium.dev';
const canonical = canonicalUrl ?? (lang === 'en' ? siteUrl : `${siteUrl}/es`);
const alternateEn = siteUrl;
const alternateEs = `${siteUrl}/es`;
const ogImage = `${siteUrl}/og-image.png`;

const personSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Kevin Hierro Carrasco",
  "url": siteUrl,
  "jobTitle": lang === 'en' ? "Full Stack Engineer" : "Ingeniero Full Stack",
  "sameAs": [
    "https://github.com/Wolfremium13",
    "https://www.linkedin.com/in/kevin-hierro/"
  ]
});
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Kevin Hierro Carrasco" />
    <meta name="robots" content="index, follow" />
    {keywords && <meta name="keywords" content={keywords} />}

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="es" href={alternateEs} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'es_ES'} />
    <meta property="og:locale:alternate" content={lang === 'en' ? 'es_ES' : 'en_US'} />
    <meta property="og:site_name" content="Wolfremium Dev" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={personSchema} />
  </head>
  <body>
    <slot />

    <!-- Back to Top Button (mobile only) -->
    <a href="#hero" class="back-to-top" id="backToTop" aria-label="Back to top">
      <span class="back-to-top-arrow">↑</span>
    </a>
  </body>
</html>

<style is:global>
  /* Base custom selections and utility scroll controls */
  ::selection {
    background-color: #7f52ff;
    color: #0b0b0e;
  }

  body {
    background-color: var(--bg-dark-obsidian);
    color: var(--text-white);
  }

  /* Back to Top Button — mobile only */
  .back-to-top {
    display: none;
  }

  @media (max-width: 768px) {
    .back-to-top {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      right: 1.25rem;
      bottom: calc(72px + 1rem + env(safe-area-inset-bottom));
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: linear-gradient(135deg, #21d789 0%, #7f52ff 100%);
      color: #0b0b0e;
      font-size: 1.2rem;
      font-weight: 800;
      box-shadow: 0 4px 20px rgba(127, 82, 255, 0.4);
      z-index: 150;
      opacity: 0;
      transform: translateY(12px) scale(0.85);
      pointer-events: none;
      transition: opacity 0.3s ease, transform 0.3s ease;
      text-decoration: none;
    }

    .back-to-top.visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .back-to-top:active {
      transform: scale(0.92);
    }
  }
</style>

<script>
  const backToTop = document.getElementById('backToTop');
  if (backToTop) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        backToTop.classList.add('visible');
      } else {
        backToTop.classList.remove('visible');
      }
    });
  }
</script>
