---
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Gradients matching the repo styles
const repos = [
  {
    name: 'estimados-front',
    type: t('projects.estimados.component.frontend'),
    stack: t('projects.estimados.stack.frontend'),
    desc: lang === 'en'
      ? 'A collaborative web app with health check fail-safe loops and real-time state synchronization.'
      : 'Aplicación web colaborativa con bucles de seguridad para comprobar la salud de la conexión y sincronización de estado.',
    url: 'https://github.com/Wolfremium13/estimados-front',
    gradient: 'var(--gradient-webstorm)',
    glow: 'var(--glow-webdev)',
    color: '#087cfa',
    badge: 'Astro 6'
  },
  {
    name: 'estimados-backend',
    type: t('projects.estimados.component.backend'),
    stack: t('projects.estimados.stack.backend'),
    desc: lang === 'en'
      ? 'Stateful ASP.NET Core API with SignalR Hubs, strict DDD patterns, and BDD behavior testing.'
      : 'API con estado en ASP.NET Core con Hubs de SignalR, patrones DDD estrictos y pruebas de comportamiento BDD.',
    url: 'https://github.com/Wolfremium13/estimados-backend',
    gradient: 'var(--gradient-rider)',
    glow: 'var(--glow-soft)',
    color: '#ff6ec7',
    badge: 'dotNET 10'
  },
  {
    name: 'estimados-iac',
    type: t('projects.estimados.component.iac'),
    stack: t('projects.estimados.stack.iac'),
    desc: lang === 'en'
      ? 'Terraform provisioning for Azure Docker apps, Key Vault secrets, and Logic App alerting on Telegram.'
      : 'Aprovisionamiento con Terraform para contenedores Azure, secretos en Key Vault y alertas mediante Logic Apps a Telegram.',
    url: 'https://github.com/Wolfremium13/estimados-iac',
    gradient: 'var(--gradient-pycharm)',
    glow: 'var(--glow-data)',
    color: '#21d789',
    badge: 'Terraform'
  }
];

const cards = [
  { icon: '🪓', label: lang === 'en' ? 'Axe Protocol' : 'Protocolo del Hacha', desc: lang === 'en' ? 'Halt and split stories with high points' : 'Detiene la votación para dividir historias complejas' },
  { icon: '📊', label: lang === 'en' ? 'Diagram Flag' : 'Bandera de Diagrama', desc: lang === 'en' ? 'Prompts visualization of system designs' : 'Solicita el diseño visual del flujo o arquitectura' },
  { icon: '🤖', label: lang === 'en' ? 'AI Spike' : 'Spike de IA', desc: lang === 'en' ? 'Flags high uncertainty to run technical spikes' : 'Marca incertidumbre para realizar pruebas de concepto' },
  { icon: '☕', label: lang === 'en' ? 'Coffee Break' : 'Pausa para Café', desc: lang === 'en' ? 'Indicates team fatigue or deadlocked discussions' : 'Señala fatiga o debate encallado del equipo' }
];
---

<section class="projects-section" id="projects">
  <div class="container">
    <div class="section-header-block">
      <h2 class="section-title">{t('section.projects.title')}</h2>
      <div class="title-line"></div>
    </div>

    <!-- Project Highlight Intro -->
    <div class="project-highlight-intro glow-card-brand">
      <div class="project-header">
        <div class="project-badge-tag">FULL STACK SHOWCASE</div>
        <h3 class="project-main-title">{t('projects.estimados.title')}</h3>
        <p class="project-main-subtitle">{t('projects.estimados.subtitle')}</p>
      </div>

      <p class="project-main-description">{t('projects.estimados.description')}</p>

      <!-- Special Cards Grid inside the Highlight -->
      <div class="special-cards-wrapper">
        <h4 class="special-cards-title">{lang === 'en' ? 'Special Action Cards (Custom Rules)' : 'Cartas de Acción Especiales (Reglas)'}</h4>
        <div class="special-cards-grid">
          {cards.map(card => (
            <div class="special-card">
              <span class="special-card-icon" aria-hidden="true">{card.icon}</span>
              <div class="special-card-info">
                <span class="special-card-label">{card.label}</span>
                <span class="special-card-desc">{card.desc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- The Repositories Grid -->
    <div class="repos-grid">
      {repos.map(repo => (
        <div class="repo-card glow-card" style={`--hover-gradient: ${repo.gradient}; --hover-glow: ${repo.glow}; --repo-color: ${repo.color}`}>
          <div class="repo-card-header">
            <div class="repo-meta-block">
              <span class="repo-type-badge">{repo.type}</span>
              <h4 class="repo-name">{repo.name}</h4>
            </div>
            <span class="repo-tech-badge" style={`border-color: ${repo.color}30; color: ${repo.color}; background: ${repo.color}0d`}>{repo.badge}</span>
          </div>

          <p class="repo-desc">{repo.desc}</p>

          <div class="repo-tech-details">
            <span class="tech-label">{lang === 'en' ? 'Technologies:' : 'Tecnologías:'}</span>
            <span class="tech-stack-text">{repo.stack}</span>
          </div>

          <div class="repo-actions-block">
            <a href={repo.url} target="_blank" rel="noopener noreferrer" class="repo-link" style={`--btn-color: ${repo.color}`}>
              <span>{t('projects.view_code')}</span>
              <span class="link-arrow">↗</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding: 100px 0;
    position: relative;
    background: linear-gradient(180deg, var(--bg-dark-obsidian) 0%, rgba(25, 25, 28, 0.2) 100%);
    border-bottom: 1px solid var(--border-color);
  }

  .section-header-block {
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 800;
    background: linear-gradient(90deg, #ffffff 0%, #a0a0a0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .title-line {
    width: 60px;
    height: 4px;
    background: var(--gradient-brand);
    margin-top: 10px;
    border-radius: 2px;
  }

  /* Main project highlight styling */
  .project-highlight-intro {
    background: var(--bg-dark-charcoal);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 2.5rem;
    margin-bottom: 2.5rem;
    position: relative;
    transition: var(--transition-smooth);
  }

  .project-highlight-intro::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 16px;
    padding: 1px;
    background: var(--gradient-border);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    transition: var(--transition-smooth);
  }

  .project-highlight-intro:hover {
    transform: translateY(-2px);
    box-shadow: var(--glow-fullstack);
  }

  .project-highlight-intro:hover::before {
    background: var(--gradient-brand);
  }

  .project-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .project-badge-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: #21d789;
    letter-spacing: 0.1em;
  }

  .project-main-title {
    font-size: 2.5rem;
    font-weight: 900;
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1.1;
  }

  .project-main-subtitle {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-white);
  }

  .project-main-description {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-gray-light);
    margin-bottom: 2rem;
    max-width: 950px;
  }

  /* Special Cards Rules Box */
  .special-cards-wrapper {
    border-top: 1px solid var(--border-color);
    padding-top: 1.5rem;
  }

  .special-cards-title {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-gray-muted);
    margin-bottom: 1.25rem;
    letter-spacing: 0.05em;
  }

  .special-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }

  .special-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #0f0f11;
    border: 1px solid var(--border-color);
    padding: 12px 16px;
    border-radius: 10px;
    transition: var(--transition-fast);
  }

  .special-card:hover {
    border-color: var(--text-gray-dark);
    background: var(--bg-dark-panel);
    transform: translateY(-1px);
  }

  .special-card-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .special-card-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .special-card-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-white);
  }

  .special-card-desc {
    font-size: 0.72rem;
    color: var(--text-gray-muted);
    line-height: 1.3;
  }

  /* Repos Grid */
  .repos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .repo-card {
    display: flex;
    flex-direction: column;
    padding: 2.25rem;
    height: 100%;
  }

  .repo-card::before {
    background: var(--gradient-border);
  }

  .repo-card:hover, .repo-card.active-hover {
    transform: translateY(-4px);
    box-shadow: var(--hover-glow);
  }

  .repo-card:hover::before, .repo-card.active-hover::before {
    background: var(--hover-gradient);
  }

  .repo-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .repo-meta-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .repo-type-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--text-gray-muted);
    letter-spacing: 0.05em;
  }

  .repo-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-white);
  }

  .repo-tech-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: 4px;
    border: 1px solid;
    line-height: 1;
    pointer-events: none;
    flex-shrink: 0;
  }

  .repo-desc {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-gray-light);
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .repo-tech-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-top: 1px dashed var(--border-color);
    padding-top: 1rem;
    margin-bottom: 1.5rem;
  }

  .tech-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--text-gray-muted);
    letter-spacing: 0.05em;
  }

  .tech-stack-text {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-white);
    line-height: 1.4;
  }

  /* Repo Github Action Button */
  .repo-actions-block {
    display: flex;
  }

  .repo-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-white);
    background: var(--bg-dark-panel);
    border: 1px solid var(--border-color);
    padding: 8px 16px;
    border-radius: 6px;
    transition: var(--transition-smooth);
    width: 100%;
    justify-content: center;
  }

  .repo-link:hover {
    border-color: var(--btn-color);
    background: color-mix(in srgb, var(--btn-color) 8%, var(--bg-dark-panel));
    box-shadow: 0 4px 12px color-mix(in srgb, var(--btn-color) 12%, transparent);
    color: var(--text-white);
  }

  .link-arrow {
    transition: transform 0.25s ease;
  }

  .repo-link:hover .link-arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 768px) {
    .project-highlight-intro {
      padding: 1.5rem;
    }

    .project-main-title {
      font-size: 2rem;
    }

    .repos-grid {
      grid-template-columns: 1fr;
    }

    .repo-card {
      padding: 1.5rem;
    }
  }
</style>
