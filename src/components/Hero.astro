---
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'en' | 'es';
  name: string;
  title: string;
  github: string;
  linkedin: string;
  email: string;
}

const { lang, name, title, github, linkedin, email } = Astro.props;
const t = useTranslations(lang);

// PDF filenames that we will copy to public/
const cvFilename = lang === 'en' 
  ? '/kevin-hierro-carrasco-en-cv-2026.pdf' 
  : '/kevin-hierro-carrasco-es-cv-2026.pdf';
---

<section class="hero-section" id="hero">
  <!-- Glowing Background Orbs -->
  <div class="glow-orb orb-green"></div>
  <div class="glow-orb orb-purple"></div>
  <div class="glow-orb orb-cyan"></div>
  
  <div class="container hero-content">
    <div class="hero-text">
      <p class="greeting">{t('hero.greeting')}</p>
      <h1 class="main-name">{name}</h1>
      <h2 class="sub-title">
        <span class="typing-text">{title}</span>
        <span class="cursor">|</span>
      </h2>
      
      <p class="location">
        <span class="loc-icon">📍</span> {t('hero.meta.location')}
      </p>
      
      <div class="cta-buttons">
        <a href="#footer" class="btn btn-primary">
          <span class="btn-text">{t('hero.cta.contact')}</span>
          <span class="btn-icon">➔</span>
        </a>
        <a href={cvFilename} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
          <span class="btn-icon-left">📥</span>
          <span class="btn-text">{t('hero.cta.cv')}</span>
        </a>
      </div>
    </div>
    
    <!-- Animated Code Terminal Mockup -->
    <div class="hero-graphic">
      <div class="terminal-box">
        <div class="terminal-window-header">
          <div class="terminal-window-buttons">
            <span class="terminal-window-btn btn-close"></span>
            <span class="terminal-window-btn btn-minimize"></span>
            <span class="terminal-window-btn btn-expand"></span>
          </div>
          <span class="terminal-window-title">bash - guest@wolfremium.dev</span>
        </div>
        <div class="terminal-window-body" data-lang={lang}>
          <div class="terminal-prompt-line">
            <span class="terminal-prompt">guest@wolfremium.dev:~$</span>
            <span class="terminal-command" id="termCommand"></span>
            <span class="terminal-cursor">█</span>
          </div>
          <div class="terminal-output" id="termOutput"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 100px;
    overflow: hidden;
  }

  /* Glowing background blobs */
  .glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(140px);
    opacity: 0.25;
    pointer-events: none;
    z-index: 1;
    animation: floatOrb 10s infinite ease-in-out alternate;
  }

  .orb-green {
    width: 350px;
    height: 350px;
    background: #21d789;
    top: 15%;
    left: -5%;
  }

  .orb-purple {
    width: 450px;
    height: 450px;
    background: #8c46ff;
    bottom: 10%;
    right: 5%;
    animation-delay: -3s;
  }

  .orb-cyan {
    width: 300px;
    height: 300px;
    background: #3cd5f7;
    top: 50%;
    left: 45%;
    animation-delay: -6s;
  }

  @keyframes floatOrb {
    0% { transform: translateY(0) scale(1); }
    100% { transform: translateY(-40px) scale(1.15); }
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .tech-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(33, 215, 137, 0.1);
    border: 1px solid rgba(33, 215, 137, 0.25);
    padding: 6px 12px;
    border-radius: 20px;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #21d789;
    box-shadow: 0 0 10px #21d789;
  }

  .badge-text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: #21d789;
  }

  .greeting {
    font-family: var(--font-mono);
    color: var(--text-gray-light);
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .main-name {
    font-size: 4rem;
    line-height: 1.1;
    font-weight: 800;
    margin-bottom: 1rem;
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 2px 20px rgba(127, 82, 255, 0.25));
  }

  .sub-title {
    font-size: 1.8rem;
    font-weight: 500;
    color: var(--text-white);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
  }

  .cursor {
    animation: blink 0.8s infinite step-end;
    color: #7f52ff;
    margin-left: 2px;
    font-weight: 700;
  }

  @keyframes blink {
    from, to { color: transparent }
    50% { color: #7f52ff; }
  }

  .location {
    font-size: 0.95rem;
    color: var(--text-gray-muted);
    margin-bottom: 2.5rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    width: 100%;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.8rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: var(--transition-smooth);
    cursor: pointer;
  }

  .btn-primary {
    background: var(--gradient-brand);
    color: #000000;
    box-shadow: 0 4px 15px rgba(127, 82, 255, 0.4);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(127, 82, 255, 0.6);
  }

  .btn-icon {
    margin-left: 8px;
    transition: transform 0.2s ease;
  }

  .btn-primary:hover .btn-icon {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: var(--bg-dark-charcoal);
    color: var(--text-white);
    border: 1px solid var(--border-color);
  }

  .btn-secondary:hover {
    background: var(--bg-dark-panel);
    border-color: var(--text-gray-dark);
    transform: translateY(-2px);
  }

  .btn-icon-left {
    margin-right: 8px;
  }

  /* Animated Terminal Styling */
  .hero-graphic {
    display: flex;
    justify-content: center;
    perspective: 1000px;
  }

  .terminal-box {
    width: 100%;
    max-width: 460px;
    background: #09090b; /* Pitch black terminal */
    border: 1px solid var(--border-color);
    border-radius: 12px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 380px;
    text-align: left;
    transform: rotateY(-8deg) rotateX(4deg);
    transition: var(--transition-smooth);
  }

  .terminal-box:hover {
    transform: rotateY(0deg) rotateX(0deg) scale(1.02);
    box-shadow: var(--glow-fullstack);
    border-color: var(--color-role-fullstack);
  }

  .terminal-window-header {
    background: #18181b; /* dark charcoal header */
    height: 38px;
    display: flex;
    align-items: center;
    padding: 0 1rem;
    border-bottom: 1px solid var(--border-color);
    position: relative;
  }

  .terminal-window-buttons {
    display: flex;
    gap: 6px;
    position: absolute;
    left: 1rem;
  }

  .terminal-window-btn {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .btn-close { background-color: #ef4444; }
  .btn-minimize { background-color: #eab308; }
  .btn-expand { background-color: #22c55e; }

  .terminal-window-title {
    width: 100%;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-gray-muted);
  }

  .terminal-window-body {
    padding: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-gray-light);
    flex-grow: 1;
    overflow-y: auto;
    position: relative;
  }

  /* Scanlines overlay */
  .terminal-window-body::before {
    content: " ";
    display: block;
    position: absolute;
    top: 0; left: 0; bottom: 0; right: 0;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.15) 50%);
    z-index: 10;
    background-size: 100% 4px;
    pointer-events: none;
  }

  .terminal-prompt {
    color: #21d789; /* Green prompt */
    font-weight: 600;
  }

  .terminal-command {
    color: #c084fc; /* Purple command color */
    font-weight: 600;
  }

  .terminal-cursor {
    animation: termBlink 1s step-start infinite;
    color: #ffffff;
    font-weight: bold;
    margin-left: 2px;
  }

  @keyframes termBlink {
    50% { opacity: 0; }
  }

  /* Line color utilities */
  .terminal-out-line {
    margin-top: 4px;
    white-space: pre-wrap;
  }

  .terminal-out-line.muted {
    color: var(--text-gray-muted);
  }

  .terminal-out-line.border {
    color: var(--border-color);
  }

  .terminal-out-line.label {
    color: #22d3ee; /* Cyan labels */
    font-weight: 600;
    display: inline-block;
  }

  .terminal-out-line span.value {
    color: #ffffff;
    font-weight: 500;
  }

  .terminal-out-line.success {
    color: #21d789; /* Green success check */
    font-weight: 600;
    margin-top: 10px;
  }

  @media (max-width: 992px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }

    .hero-text {
      align-items: center;
    }

    .main-name {
      font-size: 3rem;
    }

    .sub-title {
      font-size: 1.5rem;
    }

    .cta-buttons {
      justify-content: center;
    }

    .hero-graphic {
      order: -1;
    }
    
    .terminal-box {
      transform: none;
    }
  }

  @media (max-width: 480px) {
    .cta-buttons {
      flex-direction: column;
      gap: 0.75rem;
    }
    
    .btn {
      width: 100%;
    }
  }
</style>

<script>
  // Dynamic character typewriter effect for the role title
  const typingTextEl = document.querySelector('.typing-text');
  if (typingTextEl) {
    const fullText = typingTextEl.textContent || '';
    typingTextEl.textContent = '';
    let index = 0;
    
    function type() {
      if (index < fullText.length) {
        typingTextEl.textContent += fullText.charAt(index);
        index++;
        setTimeout(type, 70);
      }
    }
    
    // Slight initial delay before typewriting starts
    setTimeout(type, 300);
  }

  // Typewriter Terminal Animation
  const termCommand = document.getElementById('termCommand');
  const termOutput = document.getElementById('termOutput');
  const termBody = document.querySelector('.terminal-window-body');

  if (termCommand && termOutput && termBody) {
    const lang = termBody.getAttribute('data-lang') || 'en';
    const commandText = 'npx wolfremium';
    
    // Define lines to print
    const lines = lang === 'es' ? [
      { text: 'Inicializando Wolfremium CLI...', color: 'muted', delay: 350 },
      { text: '----------------------------------------', color: 'border', delay: 100 },
      { text: '● Nombre: ', color: 'label', isInline: true, delay: 100 },
      { text: 'Kevin Hierro Carrasco', color: 'value', delay: 100 },
      { text: '● Rol:    ', color: 'label', isInline: true, delay: 100 },
      { text: 'Ingeniero Full Stack', color: 'value', delay: 100 },
      { text: '● Habil:  ', color: 'label', isInline: true, delay: 100 },
      { text: 'TDD, BDD, Código Limpio', color: 'value', delay: 100 },
      { text: '● Stack:  ', color: 'label', isInline: true, delay: 100 },
      { text: '.NET, C#, Kotlin, Python, JS', color: 'value', delay: 100 },
      { text: '● Ciudad: ', color: 'label', isInline: true, delay: 100 },
      { text: 'Tenerife, España', color: 'value', delay: 100 },
      { text: '----------------------------------------', color: 'border', delay: 100 },
      { text: '✔ Diagnóstico: 100% estable. Listo.', color: 'success', delay: 300 }
    ] : [
      { text: 'Initializing Wolfremium CLI...', color: 'muted', delay: 350 },
      { text: '----------------------------------------', color: 'border', delay: 100 },
      { text: '● Name:   ', color: 'label', isInline: true, delay: 100 },
      { text: 'Kevin Hierro Carrasco', color: 'value', delay: 100 },
      { text: '● Role:   ', color: 'label', isInline: true, delay: 100 },
      { text: 'Full Stack Engineer', color: 'value', delay: 100 },
      { text: '● Skills: ', color: 'label', isInline: true, delay: 100 },
      { text: 'TDD, BDD, Clean Code', color: 'value', delay: 100 },
      { text: '● Stack:  ', color: 'label', isInline: true, delay: 100 },
      { text: '.NET, C#, Kotlin, Python, JS', color: 'value', delay: 100 },
      { text: '● Locate: ', color: 'label', isInline: true, delay: 100 },
      { text: 'Tenerife, Spain', color: 'value', delay: 100 },
      { text: '----------------------------------------', color: 'border', delay: 100 },
      { text: '✔ Diagnostics: 100% stable. Ready.', color: 'success', delay: 300 }
    ];

    let cmdIdx = 0;
    function typeCommand() {
      if (cmdIdx < commandText.length) {
        termCommand.textContent += commandText.charAt(cmdIdx);
        cmdIdx++;
        setTimeout(typeCommand, 60 + Math.random() * 40); // Variable typing speed
      } else {
        setTimeout(startOutput, 400);
      }
    }

    let lineIdx = 0;
    let currentContainer = null;

    function startOutput() {
      if (lineIdx < lines.length) {
        const line = lines[lineIdx];
        
        // If inline, append to current container, else create new paragraph
        if (!line.isInline || !currentContainer) {
          currentContainer = document.createElement('div');
          currentContainer.className = `terminal-out-line ${line.color}`;
          termOutput.appendChild(currentContainer);
        } else {
          // If it is value for the previous label
          const valSpan = document.createElement('span');
          valSpan.className = line.color;
          currentContainer.appendChild(valSpan);
          typeLineText(valSpan, line.text, () => {
            lineIdx++;
            setTimeout(startOutput, line.delay);
          });
          return;
        }

        typeLineText(currentContainer, line.text, () => {
          lineIdx++;
          setTimeout(startOutput, line.delay);
        });
      }
    }

    function typeLineText(container, text, callback) {
      if (text.startsWith('---') || text.includes('✔')) {
        container.textContent = text;
        callback();
        return;
      }
      
      let charIdx = 0;
      function typeChar() {
        if (charIdx < text.length) {
          container.textContent += text.charAt(charIdx);
          charIdx++;
          setTimeout(typeChar, 8 + Math.random() * 10); // Fast output typing
        } else {
          callback();
        }
      }
      typeChar();
    }

    // Start typing after initial load delay
    setTimeout(typeCommand, 500);
  }
</script>
